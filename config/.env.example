# ============================================================
# Configuracoes da API Binance
# ============================================================

# Chave da API (obter em: https://www.binance.com/pt-BR/support/faq/how-to-create-api-keys-on-binance-360002502072)
BINANCE_API_KEY=SUA_API_KEY_AQUI
BINANCE_API_SECRET=SUA_API_SECRET_AQUI

# ============================================================
# Configuracoes do Bot
# ============================================================

# Par de trading (padrao: BTCUSDT)
TRADING_SYMBOL=BTCUSDT

# Quantidade por ordem (em BTC)
TRADE_QUANTITY=0.001

# Intervalo entre ciclos (em segundos)
CYCLE_INTERVAL=0.5

# TTL do cache (em segundos)
CACHE_TTL_BALANCE=5
CACHE_TTL_RSI=60
CACHE_TTL_ORDERS=2

# ============================================================
# Configuracoes de Logging
# ============================================================

# Nivel de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Arquivo de log
LOG_FILE=logs/trading_bot.log

# ============================================================
# Configuracoes de Rede (WebSocket)
# ============================================================

# URL do WebSocket da Binance
WS_URL=wss://stream.binance.com:9443/ws

# URL da API REST da Binance
REST_URL=https://api.binance.com/api/v3

# Timeout de conexao (em segundos)
CONNECTION_TIMEOUT=5

# ============================================================
# Configuracoes de Seguranca
# ============================================================

# Recusar conexoes nao criptografadas (true/false)
REQUIRE_TLS=true

# Validar certificado SSL (true/false)
VERIFY_SSL=true